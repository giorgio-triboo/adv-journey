# Database - usare credenziali sicure in produzione
DATABASE_URL=postgresql://user:YOUR_SECURE_PASSWORD@db:5432/cepudb

# OBBLIGATORIO: genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Magellano
MAGELLANO_USER=your_magellano_user
MAGELLANO_PASSWORD=your_magellano_password

# Ulixe
ULIXE_USER=your_ulixe_user
ULIXE_PASSWORD=your_ulixe_password
# URL con ? va quotato per evitare problemi di parsing
ULIXE_WSDL="https://tmkprows2.cepu.it/Triboo2025.asmx?WSDL"

# RCRM Ulixe – Google Sheet (service account: copia i campi dal JSON in .env, nessun file JSON a runtime)
# Condividi il foglio con ULIXE_RCRM_GOOGLE_SA_CLIENT_EMAIL. La private key può essere una riga con \n al posto dei newline.
# ULIXE_RCRM_GOOGLE_SA_TYPE=service_account
# ULIXE_RCRM_GOOGLE_SA_PROJECT_ID=...
# ULIXE_RCRM_GOOGLE_SA_PRIVATE_KEY_ID=...
# ULIXE_RCRM_GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ULIXE_RCRM_GOOGLE_SA_CLIENT_EMAIL=...@....iam.gserviceaccount.com
# ULIXE_RCRM_GOOGLE_SA_CLIENT_ID=...
# ULIXE_RCRM_GOOGLE_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# ULIXE_RCRM_GOOGLE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
# ULIXE_RCRM_GOOGLE_SA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# ULIXE_RCRM_GOOGLE_SA_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
# ULIXE_RCRM_GOOGLE_SPREADSHEET_ID=19pQMgXp9IqzDxFsE7lBIiLZig5bMYCIOvbRJcZGfGtc
# Tab per mese (periodo YYYY-MM → es. 03-ulixe-rcrm). Vuoto + nessun GID = default {mm}-ulixe-rcrm
# ULIXE_RCRM_GOOGLE_SHEET_NAME_TEMPLATE={mm}-ulixe-rcrm
# Solo legacy: ULIXE_RCRM_GOOGLE_SHEET_GID=
# Range che include colonne IDMessaggio e RCRM (layout Ulixe esteso)
# ULIXE_RCRM_GOOGLE_COLUMN_RANGE=A1:Q

# Meta
META_ACCESS_TOKEN=your_meta_token
META_PIXEL_ID=your_pixel_id

# SMTP per alert email (es. Mandrill: smtp.mandrillapp.com:587)
SMTP_HOST=smtp.mandrillapp.com
SMTP_PORT=587
SMTP_USER=T-Direct SRL
SMTP_PASSWORD=your_mandrill_api_key
SMTP_FROM_EMAIL=insight@magellano.ai
SMTP_USE_TLS=true

# URL base app (per link nelle email di errore verso Riepilogo Ingestion)
APP_BASE_URL=
