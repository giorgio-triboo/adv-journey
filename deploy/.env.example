# Variabili obbligatorie per deploy in produzione
# Copia in .env e compila con valori reali

# Database PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=cepudb

# Connessione DB per l'app (deve corrispondere a POSTGRES_* sopra)
DATABASE_URL=postgresql://user:CHANGE_ME_SECURE_PASSWORD@db:5432/cepudb

# Chiave segreta app (genera con: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS

# Google OAuth, Magellano, Meta, Ulixe - vedere backend/.env.example
