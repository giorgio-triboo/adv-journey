# Template variabili d'ambiente
# Per sviluppo locale: copia in backend/.env
# Per deploy: vedere deploy/.env.example
#
# Esempio minimo per avviare l'app:

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cepudb

# OBBLIGATORIO - genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE

# Google OAuth (obbligatorio per login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URL base app in produzione (per OAuth redirect_uri)
APP_BASE_URL=https://insight.magellano.ai

# Opzionale: Magellano, Ulixe, Meta, SMTP - vedere backend/.env.example
